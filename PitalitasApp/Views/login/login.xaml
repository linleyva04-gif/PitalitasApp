<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PitalitasApp.Views.login.LoginView"
             Title="login"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="*, Auto, *" Padding="40">

        <VerticalStackLayout Grid.Row="0" VerticalOptions="Center" Spacing="20">
            <Image Source="pitahayaanimada.gif" 
                       IsAnimationPlaying="True"
                       HeightRequest="200" 
                       WidthRequest="200"
                       HorizontalOptions="Center"/>

            <Label Text="Pitalitas App" 
                       FontSize="36" 
                       FontAttributes="Bold" 
                       TextColor="#F5F3E9" 
                       HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <VerticalStackLayout Grid.Row="1" Spacing="20">

            <Border BackgroundColor="#F5F3E9"
                    StrokeShape="RoundRectangle 30"
                    HeightRequest="60"
                    Padding="10"
                    x:Name="GoogleButton">

                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnGoogleLoginClicked" />
                </Border.GestureRecognizers>

                <HorizontalStackLayout HorizontalOptions="Center" Spacing="15">
                    <Image Source="google.png" HeightRequest="25" VerticalOptions="Center"/>

                    <Label Text="Acceder con Google" 
                           TextColor="#181818" 
                           FontAttributes="Bold" 
                           FontSize="18"
                           VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Border>
            <Label Text="Al iniciar sesión, aceptas nuestros términos y condiciones."
                   FontSize="12"
                   TextColor="#444444"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"/>

            </VerticalStackLayout>

            <BoxView Grid.Row="2" BackgroundColor="Transparent"/>

        </Grid>
    </ContentPage>