<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PitalitasApp.Views.Admin.Pedidos"
             xmlns:converters="clr-namespace:PitalitasApp.Controllers"
             Title="Pedidos"
             xmlns:syncfusion="clr-namespace:Syncfusion.Maui.DataGrid;assembly=Syncfusion.Maui.DataGrid">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:ColorController x:Key="ColorController"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <syncfusion:SfDataGrid x:Name="dataGridPedidos"
                           ItemsSource="{Binding ListaPedidos}"
                           AutoGenerateColumnsMode="None"
                           SelectionMode="Single"
                           ColumnWidthMode="None" 
                           QueryRowHeight="dataGridPedidos_QueryRowHeight" 
                           HeaderRowHeight="45"
                           BackgroundColor="Transparent"
                           Margin="0,0,0,15">

        <syncfusion:SfDataGrid.DefaultStyle>
            <syncfusion:DataGridStyle 
            RowBackground="#1A1A1A"
            RowTextColor="White"
            HeaderRowBackground="Transparent"
            HeaderRowTextColor="#BDBDBD"
            SelectionBackground="#2A2A2A"
            GridLineColor="Transparent"/>
        </syncfusion:SfDataGrid.DefaultStyle>

        <syncfusion:SfDataGrid.Columns>

            <syncfusion:DataGridTextColumn 
                     MappingName="NombreCliente" 
                     HeaderText="Nombre Cliente"
                     Width="120"/>

            <syncfusion:DataGridTextColumn 
                        MappingName="tipo_entrega" 
                        HeaderText="Tipo de entrega"
                        LineBreakMode="WordWrap" 
                        Width="150"/>    

            <syncfusion:DataGridTextColumn 
                      MappingName="comentario" 
                      HeaderText="Detalles"
                      LineBreakMode="WordWrap" 
                      Width="150"/>    

            <syncfusion:DataGridTemplateColumn 
                        MappingName="estado" 
                        HeaderText="Estado"
                        Width="220">

                <syncfusion:DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>

                        <Frame BackgroundColor="#262626"
                           CornerRadius="14"
                           Padding="8"
                           Margin="10,6"
                           HasShadow="False"
                           BorderColor="#333"
                           MinimumWidthRequest="180"
                               VerticalOptions="Center"
                               HorizontalOptions="Center">

                            <Picker SelectedItem="{Binding estado}"
                                    TextColor="{Binding SelectedItem, Source={RelativeSource Self}, Converter={StaticResource ColorController}}"
                                    FontAttributes="Bold"
                                    FontSize="12"
                                    HorizontalOptions="Center"
                                    SelectedIndexChanged="OnEstadoChanged"
                                    MinimumWidthRequest="180"
                                    VerticalOptions="Center"
                                    HorizontalTextAlignment="Center">

                                <Picker.Items>
                                    <x:String>Pendiente</x:String>
                                    <x:String>En preparación</x:String>
                                    <x:String>En camino</x:String>
                                    <x:String>Entregado</x:String>
                                </Picker.Items>

                            </Picker>

                        </Frame>

                        
                    </DataTemplate>
                </syncfusion:DataGridTemplateColumn.CellTemplate>




                </syncfusion:DataGridTemplateColumn>

        </syncfusion:SfDataGrid.Columns>

    </syncfusion:SfDataGrid>
</ContentPage>