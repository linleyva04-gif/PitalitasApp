<?xml version="1.0" encoding="utf-8" ?>
<FlyoutPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
            xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
            x:Class="PitalitasApp.MenuAdmin"
            xmlns:local="clr-namespace:PitalitasApp"
            xmlns:models="clr-namespace:PitalitasApp.Models"
            BackgroundColor="#0A0A0A"
            Title="Menú">

    <FlyoutPage.Flyout>
        <local:contentFlyoutAdmin x:Name="flyoutPage"/>
    </FlyoutPage.Flyout>


    <FlyoutPage.Detail>
        <NavigationPage>
            <x:Arguments>


                <ContentPage BackgroundColor="#181818"
                             Title="Menú">

                    <Grid>
                        <CollectionView x:Name="ListaPlatillos"
                                        Margin="20">

                            <!-- el header -->
                            <CollectionView.Header>

                                <VerticalStackLayout Spacing="30">

                                    <!-- encabezado -->
                                    <HorizontalStackLayout Spacing="30">

                                        <Image Source="pitahaya.png"
                                                HeightRequest="80"/>

                                        <VerticalStackLayout Spacing="2" VerticalOptions="Center">

                                            <Label Text="Buenas tardes,"
                                                    TextColor="#9A9A9A"
                                                    FontSize="13"/>

                                            <Label Text="Administrador"
                                                    TextColor="White"
                                                    FontSize="26"
                                                    FontAttributes="Bold"/>

                                        </VerticalStackLayout>

                                    </HorizontalStackLayout>

                                    <!-- buscador -->

                                    <Frame BackgroundColor="#2A2A2A"
                                            CornerRadius="30"
                                            Padding="10"
                                            BorderColor="#2A2A2A"
                                            HeightRequest="50"
                                            HasShadow="False">

                                        <SearchBar Placeholder="Buscar platillo"
                                                    TextColor="White"
                                                    PlaceholderColor="DarkGray"
                                                    BackgroundColor="Transparent"/>

                                    </Frame>


                                    <!-- secciones de platillos -->

                                    <ScrollView Orientation="Horizontal">

                                        <HorizontalStackLayout Spacing="10">

                                            <Frame BackgroundColor="#F5F3E9"
                                                    CornerRadius="20"
                                                    Padding="16,8">
                                                <Label Text="Todo" TextColor="Black"/>
                                            </Frame>

                                            <Frame BackgroundColor="#1E1E1E"
                                                    CornerRadius="20"
                                                    Padding="12,6">
                                                <Label Text="Entradas" TextColor="White"/>
                                            </Frame>

                                            <Frame BackgroundColor="#1E1E1E"
                                                    CornerRadius="20"
                                                    Padding="12,6">
                                                <Label Text="Hamburguesas" TextColor="White"/>
                                            </Frame>

                                            <Frame BackgroundColor="#1E1E1E"
                                                    CornerRadius="20"
                                                    Padding="12,6">
                                                <Label Text="Boneless" TextColor="White"/>
                                            </Frame>

                                            <Frame BackgroundColor="#1E1E1E"
                                                    CornerRadius="20"
                                                    Padding="12,6"> 
                                                <Label Text="Bebidas" TextColor="White"/>
                                            </Frame>

                                        </HorizontalStackLayout>

                                    </ScrollView>

                                </VerticalStackLayout>

                            </CollectionView.Header>


                            <!-- platillos -->

                            <CollectionView.ItemsLayout>
                                <GridItemsLayout Span="2"
                                                  Orientation="Vertical"
                                                  HorizontalItemSpacing="10"
                                                  VerticalItemSpacing="10"/>
                            </CollectionView.ItemsLayout>

                            <CollectionView.ItemTemplate>

                                <DataTemplate x:DataType="models:Producto">

                                    <Frame BackgroundColor="#F5F3E9"
                                            CornerRadius="22"
                                            Padding="18"
                                            BorderColor="Transparent"
                                            WidthRequest="160"
                                            HasShadow="True">

                                        <Frame.Shadow>
                                            <Shadow Brush="#000000"
                                                     Opacity="0.6"
                                                     Radius="18"
                                                     Offset="0,8"/>
                                        </Frame.Shadow>

                                        <VerticalStackLayout Spacing="12">

                                            <Image Source="burger.png"
                                                    HeightRequest="100"
                                                    HorizontalOptions="Center"/>

                                            <VerticalStackLayout Spacing="2">

                                                <Label Text="{Binding nombre}"
                                                        FontAttributes="Bold"
                                                        FontSize="15"
                                                        TextColor="Black"/>     

                                                <Label Text="{Binding descripcion}"
                                                        FontSize="12"
                                                        TextColor="#9A9A9A"
                                                        MaxLines="2"
                                                        LineBreakMode="TailTruncation"/>

                                            </VerticalStackLayout>

                                            <Grid ColumnDefinitions="*,Auto">

                                                <Label Text="{Binding precio, StringFormat='${0:F2}'}"
                                                        FontSize="16"
                                                        FontAttributes="Bold"
                                                        TextColor="#FF6A00"/>

                                                <Button Grid.Column="1"
                                                         Text="+"
                                                         FontSize="18"
                                                         FontAttributes="Bold"
                                                         TextColor="White"
                                                         BackgroundColor="#FF6A00"
                                                         WidthRequest="36"
                                                         HeightRequest="36"
                                                         CornerRadius="15"
                                                         Clicked="OnAgregarAlCarritoClicked"
                                                         CommandParameter="{Binding .}"/>

                                            </Grid>

                                        </VerticalStackLayout>

                                    </Frame>

                                </DataTemplate>

                            </CollectionView.ItemTemplate>

                        </CollectionView>


                        <!-- el carrillo de compras -->
                        <Grid Grid.RowSpan="4" HorizontalOptions="End"  
                              VerticalOptions="End" Margin="20">
                            
                            <Button WidthRequest="60" HeightRequest="60" 
                                    CornerRadius="30" BackgroundColor="#F2F0E6" 
                                    BorderColor="#F2F0E6" BorderWidth="2" 
                                    ImageSource="carrillo.png"
                                    Clicked="AbrirCarrito"/>
                            
                            <Frame BackgroundColor="#FF6A00" 
                                   CornerRadius="10" 
                                   HeightRequest="20" 
                                   WidthRequest="20" 
                                   Padding="0"  HorizontalOptions="End" 
                                   VerticalOptions="Start" 
                                   TranslationX="5" 
                                   TranslationY="-5" 
                                   BorderColor="#FF6A00"
                                   HasShadow="False">
                                
                                <Label x:Name="LblContadorCarrito"
                                       Text="0" 
                                       FontSize="10" 
                                       HorizontalOptions="Center" 
                                       VerticalOptions="Center" 
                                       TextColor="White"/>
                            </Frame>
                        </Grid>


                        <Frame x:Name="PanelCarrito"
                               BackgroundColor="#1E1E1E"
                               CornerRadius="30"
                               Padding="20"
                               TranslationY="800"
                               HasShadow="True">

                            <VerticalStackLayout Spacing="20">

                                <Label Text="Tu carrito"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="White"/>

                                <CollectionView x:Name="ListaCarrito">

                                    <CollectionView.ItemTemplate>

                                        <DataTemplate>

                                            <Grid ColumnDefinitions="*,Auto">

                                                <Frame BackgroundColor="#F5F3E9" 
                                                       CornerRadius="15" 
                                                       HasShadow="True" 
                                                       Padding="15" 
                                                       BorderColor="#3D3D3D">

                                                    <Grid ColumnDefinitions="Auto, *, Auto" RowDefinitions="Auto, Auto" ColumnSpacing="15">

                                                        <Label Grid.Column="1" 
                                                               Grid.Row="0"
                                                               Text="{Binding nombre}" 
                                                               TextColor="#FF6A00" 
                                                               FontAttributes="Bold" 
                                                               FontSize="16" 
                                                               LineBreakMode="TailTruncation"/>

                                                        <Label Grid.Column="1" 
                                                               Grid.Row="1"
                                                               Text="{Binding seccion}" 
                                                               TextColor="Gray" 
                                                               FontSize="12" 
                                                               VerticalOptions="Start"/>

                                                        <Label Grid.Column="2" 
                                                               Grid.RowSpan="2"
                                                               Text="{Binding precio, StringFormat='${0:F2}'}" 
                                                               TextColor="#FF6A00" 
                                                               FontAttributes="Bold" 
                                                               FontSize="18" 
                                                               VerticalOptions="Center" 
                                                               HorizontalOptions="End"/>
                                                    </Grid>
                                                </Frame>

                                            </Grid>

                                        </DataTemplate>

                                    </CollectionView.ItemTemplate>

                                </CollectionView>

                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                    <Button Grid.Column="0"  
                                            Text="Realizar"
                                            ImageSource="check.png"
                                            ContentLayout="Right, 10"
                                            BackgroundColor="#F5F3E9"
                                            TextColor="#FF6A00"
                                            CornerRadius="20"
                                            HeightRequest="60"/>

                                    <Button Grid.Column="1"  
                                            Text="Cancelar"
                                            ImageSource="cancel.png"
                                            ContentLayout="Right, 10"
                                            BackgroundColor="#F5F3E9"
                                            TextColor="#FF6A00"
                                            CornerRadius="20"
                                            HeightRequest="60"
                                            Clicked="CerrarCarrito"/>
                                </Grid>
                                

                            </VerticalStackLayout>

                        </Frame>
                    </Grid>
                   
                </ContentPage>

            </x:Arguments>
        </NavigationPage>
    </FlyoutPage.Detail>

</FlyoutPage>