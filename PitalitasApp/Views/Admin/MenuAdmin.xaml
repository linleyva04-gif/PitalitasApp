<?xml version="1.0" encoding="utf-8" ?>
<FlyoutPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
            xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
            x:Class="PitalitasApp.MenuAdmin"
            xmlns:local="clr-namespace:PitalitasApp"
            xmlns:models="clr-namespace:PitalitasApp.Models"
            BackgroundColor="#0A0A0A"
            Title="Menú">

    <FlyoutPage.Flyout>
        <local:contentFlyoutAdmin x:Name="flyoutPage"/>
    </FlyoutPage.Flyout>

    <FlyoutPage.Detail>
        <NavigationPage>
            <x:Arguments>
                <ContentPage BackgroundColor="#181818" Title="Menú">

                    <Grid>
                        <CollectionView x:Name="ListaPlatillos" Margin="20">

                            <CollectionView.Header>
                                <VerticalStackLayout Spacing="30" Padding="0,0,0,20">

                                    <HorizontalStackLayout Spacing="30">
                                        <Image Source="pitahaya.png" HeightRequest="80" VerticalOptions="Center"/>
                                        <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                            <Label Text="Buenas tardes," TextColor="#9A9A9A" FontSize="13"/>
                                            <Label Text="Administrador" TextColor="White" FontSize="26" FontAttributes="Bold"/>
                                        </VerticalStackLayout>
                                    </HorizontalStackLayout>

                                    <Frame BackgroundColor="#2A2A2A" CornerRadius="30" Padding="10" 
                                           BorderColor="#2A2A2A" HeightRequest="50" HasShadow="False">
                                        <SearchBar Placeholder="Buscar platillo" TextColor="White"
                                                   PlaceholderColor="DarkGray" BackgroundColor="Transparent"/>
                                    </Frame>

                                    <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                                        <HorizontalStackLayout Spacing="10">

                                            <Frame x:Name="FrameTodoA" BackgroundColor="#F5F3E9" CornerRadius="20" Padding="16,8">
                                                <Frame.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="OnCategoriaTapped" CommandParameter="Todo"/>
                                                </Frame.GestureRecognizers>
                                                <Label x:Name="LblTodoA" Text="Todo" TextColor="Black"/>
                                            </Frame>

                                            <Frame x:Name="FrameEntradasA" BackgroundColor="#1E1E1E" CornerRadius="20" Padding="12,6">
                                                <Frame.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="OnCategoriaTapped" CommandParameter="Entradas"/>
                                                </Frame.GestureRecognizers>
                                                <Label x:Name="LblEntradasA" Text="Entradas" TextColor="White"/>
                                            </Frame>

                                            <Frame x:Name="FrameHamburguesasA" BackgroundColor="#1E1E1E" CornerRadius="20" Padding="12,6">
                                                <Frame.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="OnCategoriaTapped" CommandParameter="Hamburguesas"/>
                                                </Frame.GestureRecognizers>
                                                <Label x:Name="LblHamburguesasA" Text="Hamburguesas" TextColor="White"/>
                                            </Frame>

                                            <Frame x:Name="FrameBebidasA" BackgroundColor="#1E1E1E" CornerRadius="20" Padding="12,6">
                                                <Frame.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="OnCategoriaTapped" CommandParameter="Bebidas"/>
                                                </Frame.GestureRecognizers>
                                                <Label x:Name="LblBebidasA" Text="Bebidas" TextColor="White"/>
                                            </Frame>

                                        </HorizontalStackLayout>
                                    </ScrollView>
                                </VerticalStackLayout>
                            </CollectionView.Header>

                            <CollectionView.ItemsLayout>
                                <GridItemsLayout Span="2" Orientation="Vertical" 
                                                 HorizontalItemSpacing="10" VerticalItemSpacing="10"/>
                            </CollectionView.ItemsLayout>

                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:Producto">
                                    <Frame BackgroundColor="Transparent" CornerRadius="22" Padding="15" 
                                           BorderColor="#F5F3E9" HasShadow="True" HeightRequest="280"
                                           >
                                        <Frame.Shadow>
                                            <Shadow Brush="#000000" Opacity="0.4" Radius="10" Offset="0,5"/>
                                        </Frame.Shadow>

                                        <Grid RowDefinitions="Auto, *, Auto">

                                            <Frame Grid.Row="0" Padding="0" CornerRadius="20" IsClippedToBounds="True" BorderColor="Transparent"
                                                    HasShadow="False" HorizontalOptions="Center" HeightRequest="135" WidthRequest="135">
                                                <Image Source="{Binding imagen_url}" Aspect="AspectFill"/>
                                            </Frame>

                                            <VerticalStackLayout Grid.Row="1" Spacing="2" VerticalOptions="Start" Margin="0,10">
                                                <Label Text="{Binding nombre}" FontAttributes="Bold" FontSize="14" TextColor="#F5F3E9" MaxLines="1" LineBreakMode="TailTruncation"/>
                                                <Label Text="{Binding descripcion}" FontSize="11" TextColor="#9A9A9A" MaxLines="2" LineBreakMode="TailTruncation"/>
                                            </VerticalStackLayout>

                                            <Grid Grid.Row="2" ColumnDefinitions="*, Auto" VerticalOptions="End">
                                                <Label Text="{Binding precio, StringFormat='${0:F2}'}" 
                                                       FontSize="16" FontAttributes="Bold" 
                                                       TextColor="#FF6A00" VerticalOptions="Center"/>

                                                <Button Grid.Column="1" Text="+" FontSize="18" FontAttributes="Bold" 
                                                        TextColor="White" BackgroundColor="#FF6A00" 
                                                        WidthRequest="38" HeightRequest="38" CornerRadius="19"
                                                        Clicked="OnAgregarAlCarrito_Clicked" CommandParameter="{Binding .}"/>
                                            </Grid>
                                        </Grid>
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Grid HorizontalOptions="End" VerticalOptions="End" Margin="20">
                            <Button WidthRequest="60" HeightRequest="60" CornerRadius="30" 
                                    BackgroundColor="#F2F0E6" ImageSource="carrillo.png"
                                    Clicked="AbrirCarrito"/>
                            <Frame BackgroundColor="#FF6A00" CornerRadius="10" HeightRequest="20" WidthRequest="20" 
                                   Padding="0" HorizontalOptions="End" VerticalOptions="Start" 
                                   TranslationX="5" TranslationY="-5" InputTransparent="True">
                                <Label x:Name="LblContadorCarrito" Text="0" FontSize="10" 
                                       HorizontalOptions="Center" VerticalOptions="Center" TextColor="White"/>
                            </Frame>
                        </Grid>

                        <Frame x:Name="PanelCarrito" 
                               Grid.Row="0"
                               Grid.RowSpan="4"
                               BackgroundColor="#1E1E1E" CornerRadius="30" Padding="20" 
                               TranslationY="800" HasShadow="True" VerticalOptions="End">
                            <VerticalStackLayout Spacing="20">
                                <Grid RowDefinitions="Auto, *, Auto, 220, Auto">

                                    <Label Grid.Row="0" Text="Tu carrito" FontSize="20" FontAttributes="Bold" TextColor="White" Margin="0,0,0,15"/>

                                    <CollectionView Grid.Row="1" x:Name="ListaCarrito" Margin="0,10">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,5,0,10" ColumnSpacing="15">

                                                    <Frame Padding="0" CornerRadius="10" HeightRequest="50" WidthRequest="50" IsClippedToBounds="True" HasShadow="False" BorderColor="Transparent">
                                                        <Image Source="{Binding Producto.imagen_url}" Aspect="AspectFill"/>
                                                    </Frame>

                                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                                        <Label Text="{Binding Producto.nombre}" TextColor="White" FontAttributes="Bold" FontSize="14"/>
                                                        <Label Text="{Binding Cantidad, StringFormat='Cant: {0}'}" TextColor="#9A9A9A" FontSize="12"/>
                                                    </VerticalStackLayout>

                                                    <Label Grid.Column="2" Text="{Binding Subtotal, StringFormat='${0:F2}'}" TextColor="#FF6A00" FontAttributes="Bold" FontSize="16" VerticalOptions="Center" Margin="0,0,10,0"/>

                                                    <ImageButton Grid.Column="3" Source="trash.png" HeightRequest="20" WidthRequest="20" BackgroundColor="Transparent" Clicked="OnEliminarItemCarrito_Invoked" CommandParameter="{Binding .}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>

                                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,15,0,10">
                                        <Label Text="Total:" FontSize="18" FontAttributes="Bold" TextColor="White"/>
                                        <Label x:Name="LblTotal" Grid.Column="1" Text="$0.00" FontSize="18" FontAttributes="Bold" TextColor="#FF6A00"/>
                                    </Grid>

                                    <ScrollView Grid.Row="3" Margin="0,0,0,15">
                                        <VerticalStackLayout Spacing="10">

                                            <Frame BackgroundColor="#F5F3E9" CornerRadius="20" Padding="10" BorderColor="#F5F3E9" HasShadow="False">
                                                <Picker x:Name="PickerTipoEntrega" Title="¿Cómo recibes tu pedido?" TextColor="#FF6A00" BackgroundColor="Transparent" SelectedIndexChanged="OnTipoEntrega_SelectedIndexChanged">
                                                    <Picker.Items>
                                                        <x:String>Recoger en tienda</x:String>
                                                        <x:String>Envío a domicilio</x:String>
                                                    </Picker.Items>
                                                </Picker>
                                            </Frame>

                                            <Frame x:Name="FrameCliente" IsVisible="False" BackgroundColor="#F5F3E9" CornerRadius="20" Padding="10" BorderColor="#FF6A00" HasShadow="False">
                                                <Picker x:Name="PickerCliente" Title="Seleccione al cliente" ItemDisplayBinding="{Binding Name}" TextColor="#FF6A00" BackgroundColor="Transparent" SelectedIndexChanged="OnClienteSeleccionado_Changed"/>
                                            </Frame>

                                            <Frame x:Name="FrameDireccion" IsVisible="False" BackgroundColor="#F5F3E9" CornerRadius="20" Padding="10">
                                                <Picker x:Name="PickerDireccion" 
                                                        Title="Selecciona su dirección" 
                                                        ItemDisplayBinding="{Binding colonia}" 
                                                        TextColor="#FF6A00" />      
                                            </Frame>

                                            <Frame BackgroundColor="#F5F3E9" CornerRadius="20" Padding="10" BorderColor="#F5F3E9" HasShadow="False">
                                                <Picker x:Name="PickerMetodoPago" Title="Método de pago" TextColor="#FF6A00" BackgroundColor="Transparent">
                                                    <Picker.Items>
                                                        <x:String>Efectivo</x:String>
                                                        <x:String>Tarjeta</x:String>
                                                        <x:String>Transferencia</x:String>
                                                    </Picker.Items>
                                                </Picker>
                                            </Frame>

                                            <Frame BackgroundColor="#F5F3E9" CornerRadius="20" Padding="10" BorderColor="#F5F3E9" HasShadow="False">
                                                <Editor x:Name="EditorComentario" Placeholder="Comentarios (Ej. Sin cebolla)" HeightRequest="60" TextColor="#FF6A00" BackgroundColor="Transparent"/>
                                            </Frame>

                                        </VerticalStackLayout>
                                    </ScrollView>

                                    <Grid Grid.Row="4" ColumnDefinitions="*,*" ColumnSpacing="10">
                                        <Button Grid.Column="0" Text="Realizar" BackgroundColor="#F5F3E9" TextColor="#FF6A00" CornerRadius="20" HeightRequest="60" ImageSource="check.png" ContentLayout="Left, 10" Clicked="RealizarPedido_Clicked"/>
                                        <Button Grid.Column="1" Text="Cerrar" Clicked="CerrarCarrito" BackgroundColor="#F5F3E9" TextColor="#FF6A00" CornerRadius="20" HeightRequest="60" ImageSource="cancel.png" ContentLayout="Left, 10"/>
                                    </Grid>

                                </Grid>
                            </VerticalStackLayout>
                        </Frame>
                    </Grid>
                </ContentPage>
            </x:Arguments>
        </NavigationPage>
    </FlyoutPage.Detail>
</FlyoutPage>