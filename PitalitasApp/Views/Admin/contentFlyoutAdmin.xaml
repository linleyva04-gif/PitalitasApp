<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:PitalitasApp"
             x:Class="PitalitasApp.contentFlyoutAdmin"
             xmlns:models="clr-namespace:PitalitasApp.Models"
             Title="Menu Lateral Admin"
             BackgroundColor="Transparent">
    <Border StrokeThickness="1"
            Margin="0,25,15,0"
            VerticalOptions="Fill"
            StrokeShape="RoundRectangle 0,30,0,30">

        <Border.Stroke>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#44FFFFFF" Offset="0.0" />
                <GradientStop Color="#11FFFFFF" Offset="1.0" />
            </LinearGradientBrush>
        </Border.Stroke>

        <Border.Background>
            <SolidColorBrush Color="#E6121212" />
        </Border.Background>

        <Grid RowDefinitions="Auto, *">

        <VerticalStackLayout Grid.Row="0" Padding="30,40,30,20" Spacing="10">
            <Image Source="pitahaya.png" HeightRequest="60" HorizontalOptions="Start" />
            <Label Text="Pitalitas App" FontSize="22" FontAttributes="Bold" TextColor="White" />
            <Label Text="Administrador" FontSize="14" TextColor="Gray" />
        </VerticalStackLayout>

        <CollectionView Grid.Row="1"
                        x:Name="navMenuAdmin"
                        x:FieldModifier="public"
                        SelectionMode="Single"
                        SelectionChanged="navMenu_SelectionChangedAdmin"
                        Margin="0,10">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="20,12">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroupList>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="Selected">
                                        <VisualState.Setters>
                                            <Setter Property="BackgroundColor" Value="#33ffffff" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateGroupList>
                        </VisualStateManager.VisualStateGroups>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Image Source="{Binding IconSource}" 
                               HeightRequest="22" 
                               WidthRequest="22"
                               VerticalOptions="Center">
                            <Image.Behaviors>
                            </Image.Behaviors>
                        </Image>

                        <Label Grid.Column="1"
                               Margin="15,0"
                               Text="{Binding Title}"
                               FontSize="16"
                               TextColor="White"
                               VerticalOptions="Center" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.ItemsSource>
                <x:Array Type="{x:Type models:FlyoutPageItem}">
                        <models:FlyoutPageItem Title="Menú" IconSource="menu.png" />
                        <models:FlyoutPageItem Title="Dar de alta platillo" IconSource="food.png" />
                        <models:FlyoutPageItem Title="Clientes" IconSource="customer.png" />
                        <models:FlyoutPageItem Title="Reportes pedidos" IconSource="report.png" />
                    <models:FlyoutPageItem Title="Configuración" IconSource="settings.png" />
                </x:Array>
            </CollectionView.ItemsSource>
        </CollectionView>
    </Grid>
    </Border>
</ContentPage>