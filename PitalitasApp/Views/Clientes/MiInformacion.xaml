<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PitalitasApp.Views.Clientes.MiInformacion"
             Title="Mi Información"
             BackgroundColor="#0A0A0A">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">

            <Label Text="Tus Datos Personales" FontSize="24" FontAttributes="Bold" TextColor="White"/>

            <Frame BackgroundColor="#1E1E1E" CornerRadius="20" BorderColor="Transparent" Padding="20">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Nombre completo" TextColor="#9A9A9A" FontSize="12"/>
                    <Entry x:Name="EntryNombre" TextColor="White" BackgroundColor="Transparent"/>
                    <BoxView HeightRequest="1" Color="#333333"/>

                    <Label Text="Teléfono" TextColor="#9A9A9A" FontSize="12"/>
                    <Entry x:Name="EntryTelefono" Keyboard="Telephone" Placeholder="Ej. 687 123 4567" TextColor="White" BackgroundColor="Transparent"/>
                    <BoxView HeightRequest="1" Color="#333333"/>

                    <Button Text="Actualizar Datos" BackgroundColor="#FF6A00" TextColor="White" CornerRadius="15" Margin="0,10,0,0"/>
                </VerticalStackLayout>
            </Frame>

            <Grid ColumnDefinitions="*,Auto" Margin="0,10,0,0">
                <Label Text="Mis Direcciones" FontSize="20" FontAttributes="Bold" TextColor="White" VerticalOptions="Center"/>
                <Button Grid.Column="1" Text="+ Nueva" BackgroundColor="#2A2A2A" TextColor="#FF6A00" HeightRequest="35" CornerRadius="10" Padding="10,0" Clicked="OnMostrarFormularioDireccion_Clicked"/>
            </Grid>

            <Frame x:Name="FormularioNuevaDireccion" IsVisible="False" BackgroundColor="#1E1E1E" CornerRadius="20" BorderColor="#FF6A00" Padding="20">
                <VerticalStackLayout Spacing="10">
                    <Entry x:Name="EntryCalle" Placeholder="Calle y Número" TextColor="White" BackgroundColor="Transparent"/>
                    <BoxView HeightRequest="1" Color="#333333"/>
                    <Entry x:Name="EntryColonia" Placeholder="Colonia" TextColor="White" BackgroundColor="Transparent"/>
                    <BoxView HeightRequest="1" Color="#333333"/>
                    <Entry x:Name="EntryReferencia" Placeholder="Referencia (Ej. Portón blanco)" TextColor="White" BackgroundColor="Transparent"/>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,15,0,0">
                        <Button Grid.Column="0" Text="Cancelar" BackgroundColor="#2A2A2A" TextColor="White" CornerRadius="10" Clicked="OnCancelarDireccion_Clicked"/>
                        <Button Grid.Column="1" Text="Guardar" BackgroundColor="#FF6A00" TextColor="White" CornerRadius="10" Clicked="OnGuardarDireccion_Clicked"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <CollectionView x:Name="ListaDirecciones">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="#1E1E1E" CornerRadius="15" BorderColor="Transparent" Padding="15" Margin="0,0,0,10">
                            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15">
                                <Image Source="home.png" HeightRequest="24" WidthRequest="24" VerticalOptions="Center"/>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                    <Label Text="{Binding calle_numero}" FontAttributes="Bold" TextColor="White" FontSize="16"/>
                                    <Label Text="{Binding colonia}" TextColor="#9A9A9A" FontSize="14"/>
                                    <Label Text="{Binding referencia}" TextColor="#666666" FontSize="12" FontAttributes="Italic"/>
                                </VerticalStackLayout>
                                <ImageButton Grid.Column="2" 
                                             Source="trash.png" 
                                             HeightRequest="20" 
                                             WidthRequest="20" 
                                             VerticalOptions="Center" 
                                             BackgroundColor="Transparent"
                                             Clicked="OnEliminarDireccion_Clicked"
                                             CommandParameter="{Binding .}" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>