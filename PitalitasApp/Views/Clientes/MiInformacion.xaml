<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PitalitasApp.Views.Clientes.MiInformacion"
             Title="Mi Información"
             BackgroundColor="#181818">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">

            <Image Source="perfil_placeholder.png" 
                   HeightRequest="100" 
                   WidthRequest="100"
                   HorizontalOptions="Center" 
                   Margin="0,20,0,0"/>

            <Label Text="Tus Datos Personales" 
                   TextColor="White" 
                   FontSize="22" 
                   FontAttributes="Bold" />

            <Frame BackgroundColor="#2A2A2A" 
                   CornerRadius="20" 
                   BorderColor="Transparent" 
                   Padding="20"
                   HasShadow="True">

                <VerticalStackLayout Spacing="20">

                    <VerticalStackLayout Spacing="5">
                        <Label Text="Nombre completo" TextColor="#9A9A9A" FontSize="13" />
                        <Entry x:Name="EntNombre" 
                               Text="Luis" 
                               TextColor="White" 
                               PlaceholderColor="Gray"
                               BackgroundColor="Transparent" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="Correo electrónico" TextColor="#9A9A9A" FontSize="13" />
                        <Entry x:Name="EntCorreo" 
                               IsReadOnly="True" 
                               Text="correo@ejemplo.com" 
                               TextColor="Gray" 
                               BackgroundColor="Transparent" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="Teléfono" TextColor="#9A9A9A" FontSize="13" />
                        <Entry x:Name="EntTelefono" 
                               Keyboard="Telephone" 
                               Placeholder="Ej. 687 123 4567"
                               TextColor="White" 
                               BackgroundColor="Transparent" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="Dirección de entrega principal" TextColor="#9A9A9A" FontSize="13" />
                        <Entry x:Name="EntDireccion" 
                               Text="Guasave, Sinaloa" 
                               TextColor="White" 
                               BackgroundColor="Transparent" />
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Frame>

            <Button Text="Guardar Cambios" 
                    BackgroundColor="#FF6A00" 
                    TextColor="White" 
                    FontAttributes="Bold"
                    CornerRadius="25" 
                    HeightRequest="55" 
                    Margin="0,10,0,0"
                    Clicked="OnGuardarCambios_Clicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>