<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:PitalitasApp"
             x:Class="PitalitasApp.Views.Clientes.contentFlyoutCliente"
             BackgroundColor="#121212" 
             Title="Menu Lateral Cliente">

    <Grid RowDefinitions="Auto, *">

        <VerticalStackLayout Grid.Row="0" Padding="30,40,30,20" Spacing="10">
            <Image Source="pitahaya.png" HeightRequest="60" HorizontalOptions="Start" />
            <Label Text="Pitalitas App" FontSize="22" FontAttributes="Bold" TextColor="White" />
            <Label Text="Cliente" FontSize="14" TextColor="Gray" />
        </VerticalStackLayout>

        <CollectionView Grid.Row="1"
                        x:Name="navMenu"
                        x:FieldModifier="public"
                        SelectionMode="Single"
                        SelectionChanged="navMenu_SelectionChanged"
                        Margin="0,10">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="20,12">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroupList>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="Selected">
                                        <VisualState.Setters>
                                            <Setter Property="BackgroundColor" Value="#33ffffff" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateGroupList>
                        </VisualStateManager.VisualStateGroups>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Image Source="{Binding IconSource}" 
                               HeightRequest="22" 
                               WidthRequest="22"
                               VerticalOptions="Center" />

                        <Label Grid.Column="1"
                               Margin="15,0"
                               Text="{Binding Title}"
                               FontSize="16"
                               TextColor="White"
                               VerticalOptions="Center" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <VerticalStackLayout Grid.Row="2" Padding="20,0,20,30" VerticalOptions="End">
            <Frame BackgroundColor="#2A1515" 
                   BorderColor="#FF3B30" 
                   CornerRadius="15" 
                   Padding="15"
                   HasShadow="False">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCerrarSesion_Tapped" />
                </Frame.GestureRecognizers>

                <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                    <Image Source="cancel.png" HeightRequest="20" WidthRequest="20" />
                    <Label Text="Cerrar Sesión" TextColor="#FF3B30" FontAttributes="Bold" FontSize="16" VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </Grid>
</ContentPage>