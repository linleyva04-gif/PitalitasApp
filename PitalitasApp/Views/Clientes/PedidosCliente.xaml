<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:syncfusion="clr-namespace:Syncfusion.Maui.DataGrid;assembly=Syncfusion.Maui.DataGrid"
             x:Class="PitalitasApp.Views.Clientes.PedidosCliente"
             Title="Mis Pedidos"
             BackgroundColor="#0A0A0A">

    <Grid RowDefinitions="Auto, *">
        <Label Grid.Row="0" Text="Historial de Compras" FontSize="24" FontAttributes="Bold" 
               TextColor="White" Margin="20,20,20,10"/>

        <syncfusion:SfDataGrid Grid.Row="1" x:Name="dataGridHistorial"
                               ItemsSource="{Binding ListaPedidos}"
                               AutoGenerateColumnsMode="None"
                               ColumnWidthMode="Fill"
                               HeaderRowHeight="50"
                               RowHeight="70"
                               SelectionMode="None"
                               BackgroundColor="Transparent">

            <syncfusion:SfDataGrid.DefaultStyle>
                <syncfusion:DataGridStyle RowBackground="#1A1A1A" RowTextColor="White"
                                          HeaderRowBackground="#262626" HeaderRowTextColor="#FF6A00"
                                          GridLineColor="Transparent"/>
            </syncfusion:SfDataGrid.DefaultStyle>

            <syncfusion:SfDataGrid.Columns>
                <syncfusion:DataGridTextColumn MappingName="fecha" HeaderText="Fecha" Format="dd/MM/yy" Width="100"/>

                <syncfusion:DataGridTextColumn MappingName="total" HeaderText="Total" Format="C2" Width="90"/>

                <syncfusion:DataGridTextColumn MappingName="estado" HeaderText="Estado" Width="110"/>

                <syncfusion:DataGridTemplateColumn HeaderText="Acción">
                    <syncfusion:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Text="Cancelar" 
                                    FontSize="10"
                                    HeightRequest="35"
                                    Margin="5"
                                    BackgroundColor="#331010"
                                    TextColor="#FF3B30"
                                    IsVisible="{Binding PuedeCancelar}"
                                    Clicked="OnCancelarPedido_Clicked"
                                    CommandParameter="{Binding .}"/>
                        </DataTemplate>
                    </syncfusion:DataGridTemplateColumn.CellTemplate>
                </syncfusion:DataGridTemplateColumn>
            </syncfusion:SfDataGrid.Columns>
        </syncfusion:SfDataGrid>
    </Grid>
</ContentPage>