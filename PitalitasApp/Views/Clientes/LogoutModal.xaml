<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PitalitasApp.Views.Clientes.LogoutModal"
             BackgroundColor="#B3000000">
    <Grid VerticalOptions="Center" HorizontalOptions="Center" Padding="20">

        <Frame BackgroundColor="#1E1E1E" 
               CornerRadius="25" 
               BorderColor="Transparent" 
               HasShadow="True" 
               Padding="30">

            <VerticalStackLayout Spacing="15" WidthRequest="260">

                <Label Text="Cerrar Sesión" 
                       TextColor="White" 
                       FontSize="22" 
                       FontAttributes="Bold" 
                       HorizontalOptions="Center" />

                <Label Text="¿Estás seguro que deseas salir de tu cuenta?" 
                       TextColor="#9A9A9A" 
                       FontSize="14" 
                       HorizontalOptions="Center" 
                       HorizontalTextAlignment="Center" />

                <Grid ColumnDefinitions="*,*" ColumnSpacing="15" Margin="0,20,0,0">
                    <Button Grid.Column="0" Text="Cancelar" BackgroundColor="#2A2A2A" TextColor="White" CornerRadius="15" Clicked="OnCancelar_Clicked" />
                    <Button Grid.Column="1" Text="Salir" BackgroundColor="#FF3B30" TextColor="White" CornerRadius="15" Clicked="OnConfirmar_Clicked" />
                </Grid>
            </VerticalStackLayout>

        </Frame>
    </Grid>
</ContentPage>